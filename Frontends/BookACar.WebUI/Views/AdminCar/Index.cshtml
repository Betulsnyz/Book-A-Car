@model List<ResultCarWithBrandsDtos>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/AdminLayout/Index.cshtml";
    int count = 0;
}

<div class="page-content">
    <div class="container-fluid">

        <!-- start page title -->
        <div class="row">
            <div class="col-xl-12">
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title">Araba Listesi</h4>
                        <p class="card-subtitle mb-4">
                            Arabalarla İlgili Ekleme silme,güncelleme ,arama ve listeleme gibi işlemleri bu sayfadan üzerinden yapabilirsiniz
                        </p>
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Marka</th>
                                        <th>Model</th>
                                        <th>Km</th>
                                        <th>Vites</th>
                                        <th>Sil</th>
                                        <th>GÜncelle</th>
                                        <th>Detaylar</th>
                                        <th>Sitede gör</th>
                                        <th>Fiyat Bilgileri</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach(var item in Model)
                                    {
	                                    count++;
                                        <tr>
                                            <th scope="row">@count</th>
                                            <td>@item.BrandName</td>
                                            <td>@item.Model</td>
                                            <td>@item.Km</td>
                                            <td>@item.Trasmission</td>

                                            <td><a href="/AdminCar/RemoveCar/@item.CarID" class="btn btn-outline-danger">Sil</a></td>
											<td><a href="/AdminCar/UpdateCar/@item.CarID" class="btn btn-outline-success">Güncelle</a></td>
											<td><a href="/Carlist/CarDetail/@item.CarID" class="btn btn-outline-dark">Detaylar</a></td>
											<td><a href="/Carlist/CarDetail/@item.CarID" class="btn btn-outline-warning">Sitede gör</a></td>
											<td><a href="/Carlist/CarDetail/@item.CarID" class="btn btn-outline-warning">Fiyat Bilgileri</a></td>
                                        </tr>
                                     }
                                </tbody>
                            </table>
                            <a href="/AdminCar/CreateCar/" class="btn btn-outline-primary">yeni araç girişi</a>
                        </div>

                    </div>
                </div>

            </div>

        </div>
    </div> <!-- container-fluid -->
</div>

