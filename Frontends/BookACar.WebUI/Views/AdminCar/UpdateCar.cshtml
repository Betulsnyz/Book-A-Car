@model UpdateCarDto
@{
    ViewData["Title"] = "UpdateCar";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}
<div class="page-content">
	<div class="container-fluid">

		<div class="row">
			<div class="col-xl-12">
				<div class="card">
					<div class="card-body">
						<h4 class="card-title">Araç Güncelleme Sayfası</h4>
						<p class="card-subtitle mb-4">Araçİle ilgili Temel Bilgileri eksiksiz doldurmanız önemlidir . veri girişlerinden sonra butona tıklayarak güncelleme işlemini tamamlayabilirsiniz.</p>

						<form asp-action="UpdateCar" method="post">
							<input type="hidden" asp-for="CarID" />
							<div class="form-group">
								<label for="exampleInputBrand">Marka</label>
								<select asp-for="BrandID" class="form-control">
									@foreach (var item in (List<SelectListItem>)ViewBag.BrandValues)
									{
										<option value="@item.Value">@item.Text</option>
									}

								</select>
							</div>
							<div class="form-group">
								<label for="exampleInputModel">Model</label>
								<input type="text" class="form-control" id="exampleInputModel" asp-for="Model" placeholder="model girişi yapınız">
							</div>

							<div class="form-group">
								<label for="exampleInputCoverImage">Kapak fotoğrafı</label>
								<input type="text" class="form-control" id="exampleInputCoverImage" asp-for="CoverImageUrl" placeholder="URL giriniz">
							</div>

							<div class="form-group">
								<label for="exampleInputKm">Kilometre</label>
								<input type="number" class="form-control" id="exampleInputKm" asp-for="Km" placeholder="Kilometre girişi yapınız">
							</div>

							<div class="form-group">
								<label for="exampleInputTransmission">Vites Türü</label>
								<input type="text" class="form-control" id="exampleInputTransmission" asp-for="Trasmission" placeholder="Vites türü girişi yapınız">
							</div>

							<div class="form-group">
								<label for="exampleInputSeat">Koltuk Sayısı</label>
								<input type="number" class="form-control" id="exampleInputSeat" asp-for="Seat" placeholder="Koltuk sayısı girişi yapınız">
							</div>

							<div class="form-group p-1">
								<label>Bagaj</label>
								<select class="form-control" asp-for="Luggage">
									<option value="0">Bagaj yok</option>
									<option value="1">Bagaj var</option>
								</select>
							</div>

							<div class="form-group p-1">
								<label>Yakıt Tipi</label>
								<select class="form-control" asp-for="Fuel">
									<option value="Benzin">Benzin</option>
									<option value="Dizel">Dizel</option>
									<option value="Elektrik">Elektrik</option>
									<option value="Hybrid">Hybrid</option>
								</select>
							</div>

							<div class="form-group">
								<label for="exampleInputBigImage">Büyük Kapak Fotoğrafı</label>
								<input type="text" class="form-control" id="exampleInputBigImage" asp-for="BigImageUrl" placeholder="Büyük kapak fotoğrafı URL'si giriniz">
							</div>

							<button type="submit" class="btn btn-primary waves-effect waves-light">Aracı Güncelle</button>

						</form>

					</div>
				</div>
			</div>
		</div>
	</div>
</div>



