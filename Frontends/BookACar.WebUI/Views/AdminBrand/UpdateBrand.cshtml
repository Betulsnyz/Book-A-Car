@model UpdateBrandDto
@{
    ViewData["Title"] = "UpdateBrand";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="page-content">
	<div class="container-fluid">

		<div class="row">
			<div class="col-xl-12">
				<div class="card">
					<div class="card-body">
						<h4 class="card-title">Araç Markası Güncelleme</h4>
						<p class="card-subtitle mb-4">Araç ile ilgili Marka bilgilerini eksiksiz doldurmanız önemlidir. Veri girişlerinden sonra butona tıklayarak işlemi tamamlayabilirsiniz.</p>

						<form asp-action="UpdateBrand" method="post">

							<div class="form-group">
								<input type="hidden" asp-for="brandID" />
								<label for="exampleInputName">Marka adı</label>
								<input type="text" class="form-control" id="exampleInputName" asp-for="name" placeholder="Marka adı girişi yapınız">
							</div>

							<button type="submit" class="btn btn-primary waves-effect waves-light">Markayı Kaydet</button>
						</form>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>







