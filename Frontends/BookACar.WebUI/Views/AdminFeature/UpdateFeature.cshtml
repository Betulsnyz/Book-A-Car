@model UpdateFeatureDto
@{
    ViewData["Title"] = "UpdateFeature";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}
<div class="page-content">
	<div class="container-fluid">

		<div class="row">
			<div class="col-xl-12">
				<div class="card">
					<div class="card-body">
						<h4 class="card-title">Araç Özelliğini Güncelle</h4>
						<p class="card-subtitle mb-4">Araç ile ilgili özellikleri eksiksiz doldurmanız önemlidir. Veri girişlerinden sonra butona tıklayarak işlemi tamamlayabilirsiniz.</p>

						<form asp-action="UpdateFeature" method="post">

							<div class="form-group">
								<input type="hidden" asp-for="FeatureID" />
								<label for="exampleInputName">Özellik adı</label>
								<input type="text" class="form-control" id="exampleInputName" asp-for="Name" placeholder="Özellik adı girişi yapınız">
							</div>

							<button type="submit" class="btn btn-primary waves-effect waves-light">Özelliği güncelle</button>

						</form>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>




