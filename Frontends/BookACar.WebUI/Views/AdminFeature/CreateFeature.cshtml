@model CreateFeatureDto
@{
    ViewData["Title"] = "CreateFeature";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="page-content">
	<div class="container-fluid">

		<div class="row">
			<div class="col-xl-12">
				<div class="card">
					<div class="card-body">
						<h4 class="card-title">Yeni Araç Özelliği Girişi</h4>
						<p class="card-subtitle mb-4">Araç İle ilgili Özellikleri eksiksiz doldurmanız önemlidir . veri girişlerinden sonra butona tıklayarak işlemi tamamlayabilirsiniz.</p>

						<form asp-action="CreateFeature" method="post">

							<div class="form-group">
								<label for="exampleInputName">Özellik adı</label>
								<input type="text" class="form-control" id="exampleInputName" asp-for="Name" placeholder="Özellik adı girişi yapınız">
							</div>

							<button type="submit" class="btn btn-primary waves-effect waves-light">Özelliği Kaydet</button>

						</form>

					</div>
				</div>
			</div>
		</div>
	</div>
</div>



